{
  "name": "pi-extensions",
  "private": true,
  "description": "A collection of independently installable pi coding agent extensions",
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/questionnaire/extensions/questionnaire",
      "./packages/ask-user-question/extensions/ask-user-question"
    ]
  },
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "format": "bun run --filter '*' format",
    "format:check": "bun run --filter '*' format:check"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "typebox": "^1.0.55"
  }
}
