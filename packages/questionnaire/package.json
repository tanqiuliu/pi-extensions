{
  "name": "@tanqiuliu/pi-questionnaire",
  "version": "0.1.0",
  "description": "Tool-first questionnaire flow for pi with shared tabbed TUI and custom rendering",
  "keywords": [
    "pi-package"
  ],
  "author": "Tanqiu Liu <liutanqiu@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tanqiuliu/pi-extensions",
    "directory": "packages/questionnaire"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint extensions",
    "format": "oxfmt --write extensions",
    "format:check": "oxfmt --check extensions"
  },
  "pi": {
    "extensions": [
      "./extensions/questionnaire"
    ]
  },
  "devDependencies": {
    "@types/node": "24",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
